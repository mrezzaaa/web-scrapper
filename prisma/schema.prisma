// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Lead {
  id            String   @id @default(cuid())
  title         String
  category      String?
  address       String?
  phone         String?
  website       String?
  hasWebsite    Boolean  @default(false)
  rating        Float?
  locationQuery String
  createdAt     DateTime @default(now())
}

model Setting {
  key   String @id
  value String
}

model ContactedHistory {
  id               String   @id @default(cuid())
  originalLeadId   String?  // Keep reference just in case, though original lead might be deleted
  title            String
  category         String?
  address          String?
  phone            String?
  formattedMessage String   // The actual WA message text sent
  contactedAt      DateTime @default(now())
}
